      "Impact": "Medium",
      "Mitigation": "Allocate buffer time for troubleshooting",
      "Status": "Open"
    }
  ],
  "metadata": {
    "version": "1.0",
    "generated_by": "project-agent",
    "compatible_with": "Notion API 2022-06-28"
  }
}