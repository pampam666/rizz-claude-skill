{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Slide Structure Output Schema",
  "description": "Schema for ppt-slide-engineer skill output",
  "type": "object",
  "required": ["slide_deck"],
  "properties": {
    "slide_deck": {
      "type": "object",
      "required": ["metadata", "slides"],
      "properties": {
        "metadata": {
          "type": "object",
          "required": ["title", "total_slides", "created_timestamp"],
          "properties": {
            "title": {
              "type": "string",
              "description": "Presentation title"
            },
            "subtitle": {
              "type": "string"
            },
            "total_slides": {
              "type": "integer",
              "minimum": 1
            },
            "estimated_duration_minutes": {
              "type": "integer",
              "minimum": 1
            },
            "style_preset": {
              "type": "string",
              "enum": ["corporate", "creative", "minimal", "custom"]
            },
            "created_timestamp": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "brand_config": {
          "type": "object",
          "properties": {
            "primary_color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "secondary_color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "accent_color": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$"
            },
            "heading_font": {
              "type": "string"
            },
            "body_font": {
              "type": "string"
            },
            "logo_placement": {
              "type": "string",
              "enum": ["top-left", "top-right", "bottom-left", "bottom-right", "none"]
            }
          }
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["slide_number", "slide_type", "layout", "content"],
            "properties": {
              "slide_number": {
                "type": "integer",
                "minimum": 1
              },
              "slide_type": {
                "type": "string",
                "enum": ["title", "agenda", "content", "data", "two-column", "quote", "image", "timeline", "conclusion", "appendix"]
              },
              "layout": {
                "type": "string"
              },
              "content": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "subtitle": {
                    "type": "string"
                  },
                  "bullets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "text": {
                          "type": "string"
                        },
                        "level": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 2
                        }
                      }
                    }
                  },
                  "callout": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string"
                      },
                      "position": {
                        "type": "string",
                        "enum": ["left", "right", "bottom"]
                      }
                    }
                  },
                  "chart_spec": {
                    "type": "object",
                    "properties": {
                      "chart_type": {
                        "type": "string",
                        "enum": ["bar", "pie", "line", "area", "scatter"]
                      },
                      "title": {
                        "type": "string"
                      },
                      "data": {
                        "type": "object"
                      },
                      "colors": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "pattern": "^#[0-9A-Fa-f]{6}$"
                        }
                      }
                    }
                  },
                  "left_column": {
                    "type": "object",
                    "properties": {
                      "heading": {
                        "type": "string"
                      },
                      "bullets": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "right_column": {
                    "type": "object",
                    "properties": {
                      "heading": {
                        "type": "string"
                      },
                      "bullets": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "call_to_action": {
                    "type": "string"
                  },
                  "background_recommendation": {
                    "type": "string",
                    "enum": ["gradient", "image", "solid"]
                  }
                }
              },
              "visual_spec": {
                "type": "object",
                "properties": {
                  "background_type": {
                    "type": "string",
                    "enum": ["solid", "gradient", "image"]
                  },
                  "background_colors": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^#[0-9A-Fa-f]{6}$"
                    }
                  },
                  "icon_suggestions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "highlight_bullets": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "decorative_elements": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "speaker_notes": {
                "type": "string",
                "description": "Talking points for presenter"
              }
            }
          }
        }
      }
    }
  }
}